#!/usr/bin/env bash
# pre-commit — run the secret gate on every staged file; block the commit if any
# trips. This just calls gates/check-secrets.sh (a few lines you can read).
# Install: copy to .git/hooks/pre-commit and `chmod +x`. Reality decides, not the
# agent: re-run gates/check-secrets.sh <file> yourself on anything it flags.
set -uo pipefail

repo="$(git rev-parse --show-toplevel)"
gate="$repo/gates/check-secrets.sh"

if [ ! -x "$gate" ]; then
  echo "pre-commit: $gate not found/executable — is gates/ on this branch? (skipping)" >&2
  exit 0
fi

fail=0
while IFS= read -r f; do
  [ -f "$f" ] || continue
  if ! "$gate" "$f" >/dev/null 2>&1; then
    echo "pre-commit BLOCK: gates/check-secrets.sh tripped on: $f" >&2
    fail=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "Commit blocked by the secret gate. Inspect each file, then verify yourself:" >&2
  echo "  gates/check-secrets.sh <file>" >&2
  echo "If it is a real secret: rotate it now, keep it out of the repo. If it is a" >&2
  echo "false positive (a hash, a commit SHA), rephrase to avoid the pattern." >&2
  exit 1
fi
exit 0
