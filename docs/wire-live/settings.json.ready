{
  "model": "claude-opus-4-5-20251101",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(npm test:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ],
    "ask": [
      "Bash(git commit:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(cat | jq -r '.tool_input.command // empty'); \"$CLAUDE_PROJECT_DIR/gates/check-irreversible-git.sh\" \"$CMD\" >/dev/null 2>&1 || { echo 'BLOCKED by gates/check-irreversible-git.sh: irreversible git with no human approval. Approve with ENVELOPE_HUMAN_APPROVAL=approved, or route to Sami.' >&2; exit 2; }"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "P=$(cat | jq -r '.tool_input.file_path // empty'); [ -z \"$P\" ] && exit 0; \"$CLAUDE_PROJECT_DIR/gates/check-blast-radius.sh\" \"$P\" >/dev/null 2>&1 || { echo 'BLOCKED by gates/check-blast-radius.sh: write target is outside the repo blast radius.' >&2; exit 2; }"
          }
        ]
      }
    ]
  }
}
